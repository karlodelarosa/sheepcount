# Supabase (required for local dev and production builds)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=your-publishable-or-anon-key

# Optional: used by Next.js metadata when deployed on Vercel
# VERCEL_URL=

# Cloudflare Workers deploy
# Set the NEXT_PUBLIC_* variables above in:
# Cloudflare dashboard → Workers & Pages → sheepcount → Settings → Variables
# Or use a local .dev.vars file (gitignored) for wrangler dev/deploy.
